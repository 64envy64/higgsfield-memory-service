# --- Required for full quality (semantic retrieval + LLM extraction) ---
# Without this, the service runs in lexical-only mode:
#   - semantic retrieval and nuanced extraction degrade
#   - lexical and rule-based paths remain fully functional
OPENAI_API_KEY=

# --- Optional ---
# If set, the service requires Authorization: Bearer <token> on all endpoints
# except /health, /docs, /openapi.json.
MEMORY_AUTH_TOKEN=

# Model selection (defaults shown).
MEMORY_EXTRACTION_MODEL=gpt-4o-mini
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EXTRACTION_TIMEOUT_S=25

# Logging.
MEMORY_LOG_LEVEL=INFO
